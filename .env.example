# ── Discord Bot Credentials ──────────────────────────────────────────────────
# Get these from: https://discord.com/developers/applications

# Bot token (Bot > Token)
DISCORD_TOKEN=your_bot_token_here

# Application ID (General Information > Application ID)
CLIENT_ID=your_client_id_here

# Guild ID for instant command registration during dev (optional)
# Right-click your server → Copy Server ID (needs Developer Mode ON)
# Leave empty for global commands (takes ~1h to propagate)
GUILD_ID=your_guild_id_here

# ── Optional QCM PDF importer ────────────────────────────────────────────────
# Used by: bun run extract:qcm -- concours/example.pdf
GEMINI_API_KEY=your_gemini_api_key_here
